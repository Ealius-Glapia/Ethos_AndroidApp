<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <!-- Title -->
    <TextView
        android:id="@+id/booster_count_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/md_theme_onBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="1 Booster" />

    <!-- Booster STACK (CENTERED) -->
    <FrameLayout
        android:id="@+id/booster_stack_container"
        android:layout_width="0dp"
        android:layout_height="420dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/booster_count_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PRICE OVERLAY -->
    <LinearLayout
        android:id="@+id/price_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/rounded_transparent_background"
        android:padding="12dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="@id/booster_stack_container"
        app:layout_constraintBottom_toBottomOf="@id/booster_stack_container"
        app:layout_constraintEnd_toEndOf="@id/booster_stack_container"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/booster_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            tools:text="1500" />

        <ImageView
            android:id="@+id/token_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/token" />

    </LinearLayout>

    <!-- Horizontal divider with gaps on left and right -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:background="@color/md_theme_outlineVariant"
        app:layout_constraintTop_toBottomOf="@id/booster_stack_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>